# ── Claude API (required for AI chat) ────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (optional — enables your real voice clone) ────────────────────
# Get from: https://elevenlabs.io → Profile → API Key
# Voice ID: elevenlabs.io → Voices → your cloned voice → copy ID
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Cal.com (optional — enables real calendar booking) ───────────────────────
# Get from: https://cal.com → Settings → Developer → API Keys
# Event slug: the URL slug of your event type (e.g. "30min")
# Username: your Cal.com username
CAL_API_KEY=
CAL_EVENT_TYPE_SLUG=30min
CAL_USERNAME=ananthakrishna
